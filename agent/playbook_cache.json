{
  "connection_pool": {
    "keywords": [
      "connection pool",
      "db connections",
      "database connection",
      "pool exhausted",
      "postgresql",
      "queuepool"
    ],
    "tool_sequence": [
      {
        "tool": "get_metrics",
        "args": {
          "query": "db_connections",
          "time_range": "last_15m"
        }
      },
      {
        "tool": "get_metrics",
        "args": {
          "query": "error_rate",
          "time_range": "last_15m"
        }
      },
      {
        "tool": "get_logs",
        "args": {
          "service": "{service}",
          "time_range": "last_15m"
        }
      }
    ],
    "hit_count": 0
  },
